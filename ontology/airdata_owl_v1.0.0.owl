    <!-- http://airdata.org/ontology#hasGate -->

    <owl:ObjectProperty rdf:about="http://airdata.org/ontology#hasGate">
        <rdfs:subPropertyOf rdf:resource="http://airdata.org/ontology#InfrastructureRelation"/>
