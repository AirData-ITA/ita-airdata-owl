    <!-- http://airdata.org/ontology#accType -->

    <owl:DatatypeProperty rdf:about="http://airdata.org/ontology#accType">
        <rdfs:subPropertyOf rdf:resource="http://airdata.org/ontology#spatial"/>
        <rdfs:domain rdf:resource="http://airdata.org/ontology#TrajectoryPoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://airdata.org/ontology#acronymType -->

    <owl:DatatypeProperty rdf:about="http://airdata.org/ontology#acronymType">
        <rdfs:subPropertyOf rdf:resource="http://airdata.org/ontology#operational"/>
        <rdfs:domain rdf:resource="http://airdata.org/ontology#Flight"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://airdata.org/ontology#actualArrivalTime -->

    <owl:DatatypeProperty rdf:about="http://airdata.org/ontology#actualArrivalTime">
        <rdfs:subPropertyOf rdf:resource="http://airdata.org/ontology#arrivalEventData"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:comment>arr
Portuguese: Data e hora do pouso</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://airdata.org/ontology#actualInBlockTime -->

    <owl:DatatypeProperty rdf:about="http://airdata.org/ontology#actualInBlockTime">
        <rdfs:subPropertyOf rdf:resource="http://airdata.org/ontology#arrivalEventData"/>
        <rdfs:comment>cpos
Portuguese: Horário Real de Entrada no Gate</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://airdata.org/ontology#actualLineUpTime -->

    <owl:DatatypeProperty rdf:about="http://airdata.org/ontology#actualLineUpTime">
        <rdfs:subPropertyOf rdf:resource="http://airdata.org/ontology#departureEventData"/>
        <rdfs:comment>crwy
Portuguese: Autorização de Ingresso na Cabeceira</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://airdata.org/ontology#actualOffBlockTime -->

    <owl:DatatypeProperty rdf:about="http://airdata.org/ontology#actualOffBlockTime">
        <rdfs:subPropertyOf rdf:resource="http://airdata.org/ontology#departureEventData"/>
        <rdfs:comment>cpush
Horário Real de Saída</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://airdata.org/ontology#actualTakeoffTime -->

    <owl:DatatypeProperty rdf:about="http://airdata.org/ontology#actualTakeoffTime">
        <rdfs:subPropertyOf rdf:resource="http://airdata.org/ontology#departureEventData"/>
        <rdfs:comment>dep
Portuguese: Decolagem</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://airdata.org/ontology#actualTaxiStartTime -->

    <owl:DatatypeProperty rdf:about="http://airdata.org/ontology#actualTaxiStartTime">
        <rdfs:subPropertyOf rdf:resource="http://airdata.org/ontology#departureEventData"/>
        <rdfs:comment>taxi
Portuguese: Autorização do taxi</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://airdata.org/ontology#additionalData -->

    <owl:DatatypeProperty rdf:about="http://airdata.org/ontology#additionalData">
